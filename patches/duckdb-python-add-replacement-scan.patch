+static shared_ptr<DuckDBPyConnection> AddReplacementScanMethod(DuckDBPyConnection &self_ref,
+                                                                const py::function &callback) {
+	auto self = self_ref.shared_from_this();
+	auto &db = self->con.GetDatabase();
+	auto &config = DBConfig::GetConfig(*db.instance);
+	auto scan_data = make_uniq<PythonCallbackReplacementScanData>(callback);
+	config.replacement_scans.emplace_back(PythonCallbackReplacementScan, std::move(scan_data));
+	return self;
+}
